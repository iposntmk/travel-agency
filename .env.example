# Copy to .env and fill in values
# NEVER commit the real .env file

# Neon Postgres (Singapore region)
DATABASE_URL=

# Payload CMS — generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# Optional: LAN IP for local dev access from other devices (e.g. http://192.168.x.x:3000)
# DEV_ORIGIN=

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Cloudflare R2 — https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_BUCKET=travel-agency-media
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public URL for R2 bucket (custom domain or r2.dev URL, no trailing slash)
R2_PUBLIC_URL=https://media.yoursite.com

# Upstash QStash — https://console.upstash.com/qstash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=

# Sentry (optional — leave blank to disable)
SENTRY_DSN=
