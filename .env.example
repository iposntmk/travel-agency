# ------------------------------------------------------------------------------
# DATABASE (Neon Postgres)
# ------------------------------------------------------------------------------
# Dán chuỗi postgresql:// bạn vừa copy từ nút "Connect" trên Neon vào đây
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=verify-full&channel_binding=require"

# ------------------------------------------------------------------------------
# PAYLOAD CMS CONFIG
# ------------------------------------------------------------------------------
# Chuỗi bảo mật ngẫu nhiên mã hóa session của Payload. 
# Bạn có thể tự gõ bừa 1 chuỗi dài, hoặc chạy lệnh này ở Terminal để sinh chuỗi chuẩn:
# openssl rand -hex 32
PAYLOAD_SECRET="thay_bang_chuoi_bi_mat_ngau_nhien_cua_ban"

# URL của trang web (Local dev giữ nguyên localhost)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ------------------------------------------------------------------------------
# CLERK AUTHENTICATION (Lấy từ Dashboard của Clerk)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ------------------------------------------------------------------------------
# CLOUDFARE R2 STORAGE (Dành cho Media / Uploads - Điền sau ở Layer sau nếu chưa cần)
# ------------------------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_URL=""

# ------------------------------------------------------------------------------
# UPSTASH QSTASH & RESEND & SENTRY (Background Jobs, Email & Logs - Để lại sau)
# ------------------------------------------------------------------------------
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
RESEND_API_KEY=""
SENTRY_DSN=""
