# Copy to .env and fill in values
# NEVER commit the real .env file

# Neon Postgres (Singapore region)
DATABASE_URL=
# Optional direct Neon URL for Payload migrations when DATABASE_URL uses a pooler
DATABASE_URL_UNPOOLED=

# Payload CMS — generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# Optional: LAN IP for local dev access from other devices (e.g. http://192.168.x.x:3000)
# DEV_ORIGIN=

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk webhook endpoint signing secret
CLERK_WEBHOOK_SIGNING_SECRET=

# Cloudflare R2 — https://dash.cloudflare.com → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_BUCKET=travel-agency-media
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Public URL for R2 bucket (custom domain or r2.dev URL, no trailing slash)
R2_PUBLIC_URL=https://media.yoursite.com

# Upstash QStash — https://console.upstash.com/qstash
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Upstash Redis — REST API credentials for booking rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=An's Travel Agency <bookings@yoursite.com>
BOOKING_SALES_EMAIL=sales@yoursite.com
# Optional — Resend Audience for newsletter signups (https://resend.com/audiences).
# Leave blank to disable the homepage newsletter form gracefully.
RESEND_AUDIENCE_ID=

# Sentry (optional — leave blank to disable)
SENTRY_DSN=

# Search engine indexing — MUST stay unset (or "false") until MVP launch criteria are met.
# When falsy, the site sends X-Robots-Tag: noindex,nofollow,noarchive,nosnippet on every response
# and <meta robots="noindex"> in the public layout — no bot (Google, Bing, AI crawlers) will index it.
# See docs/CURRENT_STATUS.md → "Search Engine Indexing — Currently Disabled" before flipping to true.
# ALLOW_INDEXING=false
